# Keep this file safe to commit. Never place real keys in it.
PORT=3000

# Groq is optional. Local verified evidence still works when this is blank.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_SEMANTIC_MATCHING_ENABLED=true

# WhatsApp Cloud API test adapter. Keep disabled until Meta is configured.
WHATSAPP_CLOUD_API_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
WHATSAPP_GRAPH_API_VERSION=v25.0
